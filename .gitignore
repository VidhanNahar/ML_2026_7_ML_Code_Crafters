# Ignore all dataset contents by default
project/dataset/**

# Keep dataset folder structure and allow placeholder files
!project/dataset/**/
!project/dataset/**/.gitkeep

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Build and packaging artifacts
build/
dist/
*.egg-info/

# Logs
*.log

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# ML experiment outputs
runs/
wandb/
mlruns/
lightning_logs/
tensorboard/
events.out.tfevents.*

# Model artifacts and checkpoints
*.ckpt
*.pt
*.pth
*.onnx
*.joblib
*.pkl
